# Application bindings
$terminal = uwsm app -- $TERMINAL
$browser = omarchy-launch-browser

bindd = SUPER, RETURN, Terminal, exec, $terminal --working-directory $(omarchy-cmd-terminal-cwd)
bindd = SUPER SHIFT, F, File manager, exec, uwsm app -- nautilus --new-window
bindd = SUPER SHIFT, B, Browser, exec, $browser
bindd = SUPER SHIFT ALT, B, Browser (private), exec, $browser --private
bindd = SUPER SHIFT, M, Miro, exec, omarchy-launch-webapp "https://miro.com/app/dashboard/"
bindd = SUPER SHIFT, N, Editor, exec, omarchy-launch-editor
bindd = SUPER SHIFT ALT, T, Activity, exec, $terminal -e btop
bindd = SUPER SHIFT, D, Docker, exec, $terminal -e lazydocker
bindd = SUPER SHIFT, G, Signal, exec, omarchy-launch-or-focus signal "uwsm app -- signal-desktop"
bindd = SUPER SHIFT, O, Obsidian, exec, omarchy-launch-or-focus obsidian "uwsm app -- obsidian -disable-gpu --enable-wayland-ime"

bindd = SUPER SHIFT, slash, Passwords, exec, uwsm app -- bitwarden-desktop 

# AI STUFF
bindd = SUPER SHIFT ALT, A, ChatGPT, exec, omarchy-launch-webapp "https://chatgpt.com"
bindd = SUPER SHIFT ALT, M, Microsoft Copilot, exec, omarchy-launch-webapp "https://m365.cloud.microsoft/chat/?auth=2"
bindd = SUPER SHIFT ALT, C, Claude, exec, omarchy-launch-webapp "https://claude.ai/new"
bindd = SUPER SHIFT ALT, P, Perplexity, exec, omarchy-launch-webapp "https://perplexity.ai"
bindd = SUPER SHIFT ALT, G, Gemini, exec, omarchy-launch-webapp "https://gemini.google.com/app"
bindd = SUPER SHIFT ALT, X, Grok, exec, omarchy-launch-webapp "https://grok.com"


bindd = SUPER SHIFT, T, Teams, exec, omarchy-launch-webapp "https://teams.microsoft.com/v2/"
bindd = SUPER SHIFT, E, Emajl, exec, omarchy-launch-webapp "https://outlook.office.com/mail/inbox/"
bindd = SUPER SHIFT, Y, YouTube, exec, omarchy-launch-webapp "https://youtube.com/"
bindd = SUPER SHIFT, R, Apple Reminders, exec, omarchy-launch-webapp "https://www.icloud.com/reminders/"
bindd = SUPER SHIFT, N, Apple Notes, exec, omarchy-launch-webapp "https://www.icloud.com/notes/"
bindd = SUPER SHIFT, X, X, exec, omarchy-launch-webapp "https://x.com/"

# Overwrite existing bindings, like putting Omarchy Menu on Super + Space
# unbind = SUPER SHIFT, Space
# bindd = SUPER SHIFT, SPACE, Omarchy menu, exec, omarchy-menu

# Over ride defaults



# Move focus with SUPER + hjkl keys
bindd = SUPER SHIFT, H, Move focus left, movefocus, l
bindd = SUPER SHIFT, L, Move focus right, movefocus, r
bindd = SUPER SHIFT, J, Move focus up, movefocus, u
bindd = SUPER SHIFT, K, Move focus down, movefocus, d

# Swap active window with the one next to it with SUPER + SHIFT + arrow keys
bindd = SUPER SHIFT ALT, H, Swap window to the left, swapwindow, l
bindd = SUPER SHIFT ALT, L, Swap window to the right, swapwindow, r
bindd = SUPER SHIFT ALT, J, Swap window up, swapwindow, u
bindd = SUPER SHIFT ALT, K, Swap window down, swapwindow, d
