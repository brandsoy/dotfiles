// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "icon_theme": "Zed (Default)",
  "assistant": {
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-3-7-sonnet-latest"
    },
    "version": "2"
  },

  "base_keymap": "VSCode",
  "vim_mode": true,
  "relative_line_numbers": true,
  "theme": "Rosé Pine",
  "ui_font_size": 16,
  "buffer_font_size": 13.0,
  // "buffer_font_family": "MonaspiceKr Nerd Font Mono",
  // "buffer_font_family": "MesloLGS Nerd Font Mono",
  // "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  // "buffer_font_family": "FiraCode Nerd Font Mono",
  "buffer_font_family": "CaskaydiaCove Nerd Font Mono",
  // "buffer_font_family": "Iosevka Nerd Font Mono",
  // "buffer_font_family": "BlexMono Nerd Font Mono",
  "features": {
    "edit_prediction_provider": "zed"
  },
  "terminal": {
    "font_family": "BlexMono Nerd Font Mono"
  },
  "lsp": {
    "biome": {
      "settings": {
        "require_config_file": false
      }
    }
  },
  "soft_wrap": "editor_width"
}
