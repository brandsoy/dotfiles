// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "theme": "One Dark",
  "git_panel": {
    "sort_by_path": true
  },
  "outline_panel": {
    "dock": "right"
  },
  "agent": {
    "always_allow_tool_actions": false,
    "play_sound_when_agent_done": true,
    "default_profile": "write",
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-latest"
    },
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4"
    }
  },
  "project_panel": {
    "dock": "left"
  },
  "base_keymap": "VSCode",
  // Vim mode settings
  "vim_mode": true,
  "relative_line_numbers": true,

  // THEMEING
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "buffer_font_size": 15,
  "ui_font_family": ".ZedMono",
  "ui_font_size": 15,
  "terminal": {
    "font_family": "JetBrainsMonoNL Nerd Font Mono"
  },

  "features": {
    "edit_prediction_provider": "zed"
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": true
  },
  "soft_wrap": "editor_width",
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  // File syntax highlighting
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"]
  },
  "scrollbar": {
    "show": "auto"
  },

  // File scan exclusions, hide on the file explorer and search
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    // above is default from Zed
    "**/out",
    "**/dist",
    "**/.husky",
    "**/.turbo",
    "**/.vscode-test",
    "**/.vscode",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/report",
    "**/node_modules"
  ],
  "languages": {
    "SQL": {
      "formatter": {
        "external": {
          "command": "/Users/mattis/Library/pnpm/sql-formatter",
          "arguments": ["--language", "postgresql"]
        }
      },
      "format_on_save": "on"
    },
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "indent_size": 2,
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "indent_size": 2,
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "TSX": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "indent_size": 2,
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JSON": {
      "indent_size": 2,
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JSONC": {
      "indent_size": 2,
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "Markdown": {
      "format_on_save": "on",
      "use_on_type_format": false,
      "preferred_line_length": 80,
      "soft_wrap": "preferred_line_length",
      "prettier": {
        "allowed": true
      }
    },
    "Python": {
      "indent_size": 2,
      "language_servers": ["ruff"],
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "ruff"
          }
        }
      ],
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll.ruff": true
      }
    },
    "SCSS": {
      "indent_size": 2,
      "code_actions_on_format": {
        "source.fixAll.stylelint": true
      },
      "prettier": {
        "allowed": true
      }
    },
    "CSS": {
      "indent_size": 2,
      "code_actions_on_format": {
        "source.fixAll.stylelint": true
      },
      "prettier": {
        "allowed": true
      }
    },
    "Diff": {
      "remove_trailing_whitespace_on_save": false,
      "ensure_final_newline_on_save": false
    },
    "HTML": {
      "prettier": {
        "allowed": true
      }
    },
    "YAML": {
      "prettier": {
        "allowed": true
      }
    }
  },
  "lsp_highlight_debounce": 100,
  "tabs": {
    "git_status": true,
    "file_icons": true
  },
  "lsp": {
    "eslint": {
      "settings": {
        "codeActionOnSave": {
          "rules": ["import/order"]
        }
      }
    }
  },
  "collaboration_panel": {
    "button": false
  }
}
