bold-is-bright = true
background-opacity = 0.98
background-blur-radius = 30
mouse-hide-while-typing = true

# theme = Zenwritten Dark
# theme = Vesper
# theme = Ayu Mirage
# theme = Rose Pine
# theme = dark:Nord Wave,light:Nord Light
# theme = dark:Catppuccin Mocha, light:Catppuccin Latte
# theme = rose-pine
theme = dark:Rose Pine,light:Rose Pine Dawn
# theme = ayu
# theme = GitHub-Dark-Default

# Titlebar
macos-titlebar-style = "transparent"
macos-titlebar-proxy-icon = "hidden"

# Font
font-size = 14
font-family = "CaskaydiaMono Nerd Font Mono"
# font-feature = calt
# font-feature = liga
# font-feature = dig
# font-synthetic-style = true

adjust-cell-height = 10%

# Misc
shell-integration-features = "sudo,title"
quit-after-last-window-closed = "true"
cursor-style = bar
cursor-style-blink = true

# Icon
macos-icon = custom-style
macos-icon-frame = "plastic"
macos-icon-ghost-color = purple

mouse-scroll-multiplier = 2
window-save-state = always
window-colorspace = "display-p3"
fullscreen = true
maximize = true

# Windows Padding
window-padding-balance = true
window-padding-x = 5 
window-padding-y = 5 

# Window hide top bar
# window-decoration = "none"
macos-titlebar-style = hidden

# Key bindings
keybind = ctrl+`=toggle_quick_terminal

