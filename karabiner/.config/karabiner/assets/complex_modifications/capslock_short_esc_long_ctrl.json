
{
  "title": "Caps Lock Short Press as Esc, Long Press as Left Ctrl",
  "rules": [
    {
      "description": "Short press Caps Lock for Esc, long press for Left Ctrl",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to_if_alone": [
            {
              "key_code": "escape"
            }
          ],
          "to_if_held_down": [
            {
              "key_code": "left_control"
            }
          ]
        }
      ]
    }
  ]
}
