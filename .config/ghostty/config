
# Theme
# bold-is-bright = true
background-opacity = 0.9
background-blur-radius = 30
mouse-hide-while-typing = true
theme = xcodedarkhc
# theme = catppuccin-mocha
# foreground = CBE0F0
# background = 011423
# cursor-color= 47FF9C
# selection-background = 033259
# selection-foreground = CBE0F0
# ansi = { 214969, E52E2E, 44FFB1, "#FFE073", "#0FC5ED", "#a277ff", "#24EAF7", "#24EAF7" },
# brights = { 214969", "#E52E2E", "#44FFB1", "#FFE073", "#A277FF", "#a277ff", "#24EAF7", "#24EAF7" },

# Titlebar
macos-titlebar-style = "transparent"
macos-titlebar-proxy-icon = "hidden"

# Font
# font-family = "JetBrainsMono Nerd Font Mono"
# font-size = 16
font-family = MesloLGS Nerd Font Mono
font-size = 19

# adjust-cell-height = 20%

# Misc
shell-integration-features = "sudo,title"
quit-after-last-window-closed = "true"
cursor-style = block

# Icon
macos-icon = custom-style
macos-icon-frame = "plastic"
macos-icon-ghost-color = purple

mouse-scroll-multiplier = 2
window-padding-balance = true
window-save-state = always
window-colorspace = "display-p3"

# Key bindings
keybind = ctrl+h=goto_split:left
keybind = cmd+s>n=new_window
keybind = ctrl+j=goto_split:bottom
keybind = ctrl+k=goto_split:top
keybind = ctrl+l=goto_split:right
keybind = ctrl+shift+h=new_split:left
keybind = ctrl+shift+j=new_split:down
keybind = ctrl+shift+k=new_split:up
keybind = ctrl+shift+l=new_split:right
keybind = super+shift+enter=new_split:auto
keybind = super+shift+i=inspector:toggle
keybind = super+shift+r=reload_config
keybind = super+t=new_tab
# custom-shader = "/Users/pdz/.config/ghostty/ghostty-shaders/sparks-from-fire.glsl"

# tabs
keybind = cmd+s>c=new_tab
keybind = cmd+s>shift+l=next_tab
keybind = cmd+s>shift+h=previous_tab
keybind = cmd+s>comma=move_tab:-1
keybind = cmd+s>period=move_tab:1

# split
keybind = cmd+s>\=new_split:right
keybind = cmd+s>-=new_split:down
keybind = cmd+s>j=goto_split:bottom
keybind = cmd+s>k=goto_split:top
keybind = cmd+s>h=goto_split:left
keybind = cmd+s>l=goto_split:right
keybind = cmd+s>z=toggle_split_zoom
keybind = cmd+s>e=equalize_splits

# other
copy-on-select = clipboard
