{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@mohak34/opencode-notifier@latest"
  ],
  "provider": {
    "ollama": {
      "models": {
        "gemma4-coding": {
          "_launch": true,
          "name": "gemma4-coding",
          "parameters": {
            "num_ctx": 32768,
            "num_gpu": 99,
            "reasoning_effort": "none",
            "repeat_penalty": 1,
            "temperature": 0.2
          },
          "tools": true
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  }
}
