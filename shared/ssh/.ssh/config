# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config

# Host debsrv
#         Hostname 192.168.1.10
#         User mattis
#         ProxyCommand none
#         ForwardAgent no
#         ForwardX11 no
#         Port 22
#         KeepAlive yes
#         IdentityFile ~/.ssh/id_ed25519

Host nas
        Hostname 192.168.1.11
        User mattis
        ProxyCommand none
        ForwardAgent no
        ForwardX11 no
        Port 22
        KeepAlive yes
        IdentityFile ~/.ssh/id_ed25519


# Use port 443 for GitHub SSH
Host github.com
  HostName ssh.github.com
  Port 443
  User git
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes
  ServerAliveInterval 30
  ServerAliveCountMax 4

# Key for Insight DevOps
Host dev.azure.com
    HostName dev.azure.com
    User git
    IdentityFile ~/.ssh/id_rsa
    IdentitiesOnly yes

Host *
  AddKeysToAgent yes
  IdentityFile ~/.ssh/id_ed25519

# macOS only — UseKeychain is not recognised on Linux and will produce warnings
Match exec "uname | grep -q Darwin"
  UseKeychain yes
