#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dotfiles}"
UPDATE_SCRIPT="$DOTFILES_DIR/scripts/update-tools.sh"

if [[ ! -x "$UPDATE_SCRIPT" ]]; then
  echo "dotfiles-update: not found or not executable: $UPDATE_SCRIPT" >&2
  echo "Set DOTFILES_DIR if your repo is in a different location." >&2
  exit 1
fi

exec "$UPDATE_SCRIPT" "$@"
