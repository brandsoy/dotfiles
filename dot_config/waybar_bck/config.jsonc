// -*- mode: jsonc -*-
{
  "position": "top",
  "spacing": 4,
  "include": [
    "~/.config/waybar/modules.jsonc"
  ],
  "modules-left": [
    "hyprland/workspaces"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "group/connectivity",
    "group/multimedia",
    "battery",
    "custom/keyboard-layout",
    "custom/notification"
  ]
}
